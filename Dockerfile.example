# ── Environment Forge ────────────────────────────────────────────────────
# Example Dockerfile — vault on a Docker named volume, NOT in project dir.
#
# Build:   docker build -t myapp .
# Run:     docker run -v eforge_data:/eforge myapp
#
# See examples/ for full Dockerfile and docker-compose.yml

FROM python:3.12-slim

WORKDIR /app

# Install environment-forge
RUN pip install --no-cache-dir environment-forge

# Vault lives on a named volume — NOT in /app
VOLUME /eforge

# Copy only application code
COPY . .

# environment_forge.load() auto-detects /eforge
CMD ["python", "main.py"]
